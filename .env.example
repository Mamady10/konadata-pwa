# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://wrwhoqtxttthmqfocmab.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# PostgreSQL direct (pour npm run deploy:schema)
# Dashboard → Settings → Database → Database password
SUPABASE_DB_PASSWORD=your-database-password

# Audit RLS : npm run audit:rls accepte aussi SUPABASE_SERVICE_ROLE_KEY (migration 056)
# ou DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[ref].supabase.co:5432/postgres

# KonaAI — backends LLM interchangeables (couche lib/ai/providers)
# Fournisseur principal : openai | azure-openai | anthropic | google | offline
# KONA_AI_PROVIDER=openai
# Bascule auto si le principal est en panne (HTTP 5xx) — ex. openai,anthropic
# KONA_AI_FALLBACK_PROVIDERS=anthropic

# OpenAI (défaut actuel — gpt-4o-mini)
OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_VISION_MODEL=gpt-4o-mini

# Azure OpenAI (préparé — implémentation provider à brancher)
# AZURE_OPENAI_ENDPOINT=https://xxx.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini

# Anthropic / Google (préparé — stubs dans lib/ai/providers/stubs.ts)
# ANTHROPIC_API_KEY=
# GOOGLE_AI_API_KEY=

# Migration Supabase 051 requise pour la recherche documentaire (search_text + RPC)

# WhatsApp Business API (OTP sondages — canal whatsapp)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# OTP sondages publics — SMS via Twilio (canal sms)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=
# En local sans Twilio : affiche le code dans l'UI (true par défaut en dev)
# SURVEY_OTP_DEV_MODE=true
# AUTH_OTP_DEV_MODE=true

# Comptes par téléphone (inscription / connexion) — réutilise Twilio / WhatsApp ci-dessus
# Secret HMAC empreintes / IP (prod obligatoire)
# SURVEY_SECURITY_HMAC_SECRET=

# App — prod : https://konadatagn.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Facturation — webhook Orange Money (HMAC-SHA256 du corps brut)
ORANGE_MONEY_WEBHOOK_SECRET=
# Alias accepté :
# BILLING_WEBHOOK_SECRET=

# Cron rappels J-30 / J-7 (Vercel Cron ou appel manuel)
# Authorization: Bearer <secret> ou header x-cron-secret
CRON_SECRET=

# Email transactionnels (Resend — https://resend.com)
RESEND_API_KEY=
# Test : onboarding@resend.dev | Prod : domaine vérifié konadatagn.com
RESEND_FROM_EMAIL="KonaData <onboarding@resend.dev>"
# Prod (après vérification Resend) :
# RESEND_FROM_EMAIL="KonaData <noreply@konadatagn.com>"
# Boîte contact + alertes CEO (formulaire landing, nouvelles inscriptions org)
KONA_CONTACT_INBOX=contact@konadatagn.com
